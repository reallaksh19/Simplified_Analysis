{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Benchmark Case Schema",
  "type": "object",
  "required": [
    "caseId",
    "title",
    "module",
    "engineeringLevel",
    "input",
    "expected",
    "sourceStatus"
  ],
  "properties": {
    "caseId": {
      "type": "string",
      "description": "Unique identifier for the benchmark case."
    },
    "title": {
      "type": "string",
      "description": "Human-readable title."
    },
    "module": {
      "type": "string",
      "description": "The target module for this benchmark."
    },
    "engineeringLevel": {
      "type": "string",
      "enum": ["SCREENING", "DESIGN_AID", "REFERENCE", "DATA_INTERFACE"],
      "description": "The engineering level of the target calculation."
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the test case."
    },
    "input": {
      "type": "object",
      "description": "Input payload to be passed to the solver."
    },
    "expected": {
      "type": "object",
      "description": "Expected result payload."
    },
    "tolerance": {
      "type": "object",
      "description": "Tolerance limits for numeric comparisons.",
      "additionalProperties": {
        "type": "number"
      }
    },
    "source": {
      "type": "string",
      "description": "The origin of the expected values (e.g., hand calc, spl2)."
    },
    "sourceStatus": {
      "type": "string",
      "enum": ["VERIFIED", "PENDING_NUMERIC_EXTRACTION", "HAND_CALC", "SPL2_REFERENCE"],
      "description": "Status of the source/expected values."
    },
    "applicableSolvers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of solvers this benchmark applies to."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for grouping or filtering benchmarks."
    },
    "notes": {
      "type": "string",
      "description": "Any additional notes or warnings."
    }
  }
}
