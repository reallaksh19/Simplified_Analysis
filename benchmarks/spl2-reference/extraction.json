  "spl2_loop_algo.js": {
    "functions": [
      "calcLoopFromSpreadsheet"
    ],
    "inputs": [],
    "formulas": [
      [
        "V23",
        "D (in)\n    // V24 = t (in)\n    // V27 = R (bend radius) -> typically D * 1.5\n    // V30 = S (ft)\n    // V31 = G (ft)\n    // V32 = H (ft)\n    // V33 = W (ft)\n    // V21 = Ec (Msi)\n    // V22 = e (in/100ft) -> Extracted from C-1 usually\n\n    // Formula Mapping (V42 to V60):\n    // V42 (h): =V24*V27 / ((V23-V24)/2)^2\n    const R = D * 1.5"
      ],
      [
        "h",
        "(t * R) / Math.pow((D - t) / 2, 2)"
      ],
      [
        "k",
        "h === 0 ? 0 : 1.65 / h"
      ],
      [
        "beta",
        "h === 0 ? 0 : 0.9 / Math.pow(h, 2 / 3)"
      ],
      [
        "L",
        "2 * Math.PI * (R / 12) * k + 2 * H + G - 8 * (R / 12)"
      ],
      [
        "Z_bar",
        "L === 0 ? 0 : (Math.PI * (R / 12) * k + W + H - 4 * (R / 12)) * H / L"
      ],
      [
        "AA",
        "(2 * W + H - 6 * (R / 12)) * Math.pow(H, 2) / 2"
      ],
      [
        "BB",
        "Math.pow(H - 2 * (R / 12), 3) / 6"
      ],
      [
        "CC",
        "((Math.pow(H, 2) + 3 * Math.pow(R / 12, 2) - 2 * H * (R / 12)) * Math.PI / 4 + H * (R / 12) - 2 * Math.pow(R / 12, 2)) * 4 * (R / 12) * k"
      ],
      [
        "Ix",
        "AA + BB + CC - Math.pow(Z_bar, 2) * L"
      ]
    ]
  }
}